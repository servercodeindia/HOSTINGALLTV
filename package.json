{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "npx vite build",
    "build:server": "esbuild server/index.ts --platform=node --bundle --format=esm --external:dotenv/config --outfile=dist/index.js",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "dotenv": "^16.4.5",
    "pg": "^8.11.5",
    "drizzle-orm": "^0.30.10",

    "react": "^18.2.0",
    "react-dom": "^18.2.0",

    "wouter": "^3.3.5",
    "@tanstack/react-query": "^5.59.16",
    "lucide-react": "^0.395.0",
    "framer-motion": "^11.0.17",

    "@radix-ui/react-tooltip": "^1.1.6",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-checkbox": "^1.1.6",
    "@radix-ui/react-label": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.6",

    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4",
    "class-variance-authority": "^0.7.1",
    "react-hook-form": "^7.53.2",
    "@hookform/resolvers": "^3.9.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "vite": "^7.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild": "^0.20.2",
    "tsx": "^4.19.2",
    "typescript": "^5.3.3",
    "tailwindcss": "^3.4.17",
    "postcss": "^8.4.35",
    "autoprefixer": "^10.4.19"
  }
}
