{
  "name": "rest-express",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "npx vite build",
    "build:server": "esbuild server/index.ts --platform=node --bundle --format=esm --outfile=dist/index.js --external:vite --external:lightningcss",
    "start": "node dist/index.js",
    "db:push": "npx drizzle-kit push"
  },
  "dependencies": {
    "express": "^4.21.2",
    "pg": "^8.16.3",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.0",
    "zod": "^3.24.2",
    "dotenv": "^17.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "vite": "^7.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.9.3",
    "tsx": "^4.21.0",
    "esbuild": "^0.25.12",
    "cross-env": "^7.0.3",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "postcss": "^8.4.47",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.8"
  }
}
