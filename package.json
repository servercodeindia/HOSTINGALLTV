{
  "name": "rest-express",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "esbuild server/index.ts --platform=node --format=esm --outdir=dist --packages=external",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "express": "^4.21.2",
    "pg": "^8.16.3",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.0",
    "dotenv": "^17.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "vite": "^7.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "esbuild": "^0.25.12",
    "cross-env": "^7.0.3",
    "tailwindcss": "^3.4.17",
    "postcss": "^8.4.47",
    "autoprefixer": "^10.4.20"
  }
}
