{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "npx vite build",
    "build:server": "esbuild server/index.ts --platform=node --bundle --format=esm --external:dotenv/config --outfile=dist/index.js",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.11.5",
    "drizzle-orm": "^0.30.10"
  },
  "devDependencies": {
    "esbuild": "^0.20.2",
    "tsx": "^4.19.2",
    "vite": "^7.3.0"
  }
}
