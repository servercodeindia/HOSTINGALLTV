{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "npx vite build",
    "build:server": "esbuild server/index.ts --platform=node --bundle --format=esm --outfile=dist/index.js --external:dotenv/config --external:lightningcss",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.30.10",
    "drizzle-zod": "^0.5.1",
    "pg": "^8.11.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "lucide-react": "0.395.0"
  },
  "devDependencies": {
    "vite": "^7.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.4.5",
    "tsx": "^4.19.2",
    "esbuild": "^0.25.0",
    "tailwindcss": "^3.4.17",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3"
  }
}
