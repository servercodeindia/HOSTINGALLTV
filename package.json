{
  "name": "rest-express",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",

    "build": "npm run build:client && npm run build:server",

    "build:client": "npx vite build",

    "build:server": "esbuild server/index.ts --platform=node --format=esm --outdir=dist --packages=external",

    "start": "node dist/index.js",

    "db:push": "npx drizzle-kit push"
  },
  "dependencies": {
    "express": "^4.21.2",
    "pg": "^8.11.5",
    "drizzle-orm": "^0.38.2",
    "drizzle-zod": "^0.6.0",
    "zod": "^3.23.8",
    "dotenv": "^17.2.3",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "vite": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.4",

    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "esbuild": "^0.25.0",
    "cross-env": "^7.0.3",

    "tailwindcss": "^4.0.0",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20",

    "drizzle-kit": "^0.31.8"
  }
}
